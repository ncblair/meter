#!/usr/bin/env bash
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="$REPO/target/release/tui_meter"

if [[ ! -x "$BIN" ]] \
  || [[ "$REPO/src/main.rs" -nt "$BIN" ]] \
  || [[ "$REPO/Cargo.toml" -nt "$BIN" ]] \
  || [[ "$REPO/Cargo.lock" -nt "$BIN" ]]; then
  (cd "$REPO" && cargo build --release)
fi

exec "$BIN" "$@"
